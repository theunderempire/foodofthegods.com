    "_id": { "$oid": "6244eb84c0198f0014e646ba" },
    "name": "Tomato Basil Pasta",
    "prepDuration": "5 min",
    "cookDuration": "25 min",
    "servings": "4",
    "imageUrl": "https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9?w=800",
    "ingredients": [
      {
        "name": "spaghetti or linguine",
        "unit": "oz",
        "amount": "12",
        "id": 1
      },
      {
        "name": "crushed San Marzano tomatoes",
        "unit": "oz",
        "amount": "28",
        "id": 2
      },
      { "name": "garlic cloves", "unit": "", "amount": "4", "id": 3 },
      { "name": "olive oil", "unit": "tbsp", "amount": "3", "id": 4 },
      { "name": "fresh basil", "unit": "leaves", "amount": "15", "id": 5 },
      { "name": "red pepper flakes", "unit": "tsp", "amount": "0.25", "id": 6 },
      { "name": "salt", "unit": "", "amount": "", "id": 7 },
      { "name": "parmesan", "unit": "", "amount": "", "id": 8 }
    ],
    "directions": [
      {
        "text": "Cook pasta in well-salted boiling water until al dente. Reserve 1 cup of pasta water before draining.",
        "duration": "10 min",
        "id": 1
      },
      {
        "text": "While pasta cooks, warm olive oil over medium heat. Add sliced garlic and red pepper flakes and cook until fragrant, about 2 minutes.",
        "duration": "2 min",
        "id": 2
      },
      {
        "text": "Add crushed tomatoes, season with salt, and simmer for 15 minutes until slightly thickened.",
        "duration": "15 min",
        "id": 3
      },
      {
        "text": "Toss drained pasta into the sauce with a splash of pasta water. Tear in fresh basil and toss to combine.",
        "duration": "2 min",
        "id": 4
      },
      { "text": "Serve with grated parmesan.", "duration": "", "id": 5 }
    ],
    "userId": "658729026be8d220c4485c9b14fd1e26"
  }
]
