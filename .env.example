# MongoDB + API
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_HOST_NAME=

# API
JWT_SECRET=
GEMINI_API_KEY=
REGISTRATION_EMAIL=

# SMTP (for registration emails)
# Set SMTP_HOST to host.docker.internal if using the host's local mail server
SMTP_HOST=localhost
SMTP_PORT=25
# Set to false if using a local/self-signed cert
SMTP_REJECT_UNAUTHORIZED=true
