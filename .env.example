# MongoDB + API
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_HOST_NAME=

# API
JWT_SECRET=
GEMINI_API_KEY=

# URLs used in registration emails (no trailing slash)
APP_URL=https://theunderempire.com/foodofthegods
API_URL=https://theunderempire.com/foodofthegods-api

# SMTP (for registration emails)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com, SMTP_PASS=<app-password>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Set to false only if using a self-signed cert
SMTP_REJECT_UNAUTHORIZED=true
